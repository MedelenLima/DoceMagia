@inject DoceMagia.Services.IUserService userService
@{
    var usuario = await userService.GetUsuarioLogado();
}

<div class="profile-section">
    @if (usuario == null)
    {
        <a asp-action="Login" asp-controller="Account" style="text-decoration: none;">
            <div class="profile-preview">
                <!-- Imagem do usuário logada: usaremos uma foto ilustrativa (logado) -->
                <img class="avatar-img" src="~/img/usuarios/no-photo.png"
                     alt="Avatar do Usuário">
                    <div class="user-info">
                        <div class="user-name">Visitante</div>
                        <div class="user-role"><i class="fas fa-chef-hat"></i>Não Logado</div>
                    </div>
                </div>
            </a>
        }
    else
        {
            <div class="profile-preview">
                <!-- Imagem do usuário logada: usaremos uma foto ilustrativa (logado) -->
                <img class="avatar-img" alt="Avatar do Usuário"
                     src="@(usuario.Foto ?? Url.Content("~/img/usuarios/no-photo.png"))"
                     alt="Avatar do Usuário">
                <div class="user-info">
                    <div class="user-name">@usuario.Nome</div>
                    <div class="user-role"><i class="fas fa-chef-hat"></i>@usuario.Perfil</div>
                </div>
            </div>
            <!-- Menu suspenso -->
            <div class="dropdown-menu">
                <div class="dropdown-item"><i class="fas fa-user"></i> Meu perfil</div>
                <div class="dropdown-item"><i class="fas fa-sliders-h"></i> Configurações</div>
                <form asp-action="Logout" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="dropdown-item"
                        style="all:unset; width:100%; padding: 0.9rem 1.4rem;">
                        <i class="fas fa-sign-out-alt" style="margin-right: 10px;"></i> Sair
                    </button>
                </form>

            </div>
        }
    </div>